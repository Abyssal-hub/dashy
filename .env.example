# Dashy Environment Configuration
# Copy this file to .env and update the values

# Database
POSTGRES_USER=dashy
POSTGRES_PASSWORD=changeme-strong-password
POSTGRES_DB=dashy
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Backend
BACKEND_PORT=8000
SECRET_KEY=your-secret-key-here-min-32-characters-long

# Full URLs (auto-generated from above, only override if needed)
# DATABASE_URL=postgresql+asyncpg://dashy:password@postgres:5432/dashy
# REDIS_URL=redis://redis:6379/0
